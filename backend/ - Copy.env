# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=SAP Analytics Chatbot
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-string

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Local dev: use the direct connection (port 5432)
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Replace "postgresql://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres.yhsipgztvctbxwojhrrn:Vedika%401357%23@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# Redis (local dev — or use Upstash for cloud)
REDIS_URL=redis://localhost:6379/0

# ─── SAP S/4HANA Connection ───────────────────────────────────────────────────
SAP_BASE_URL=https://your-s4-system.yourcompany.com
SAP_CLIENT=100
SAP_AUTH_TYPE=basic          # basic | oauth2 | principal

# Basic Auth (if SAP_AUTH_TYPE=basic)
SAP_USERNAME=CHATBOT_USER
SAP_PASSWORD=your-sap-password

# OAuth 2.0 (if SAP_AUTH_TYPE=oauth2)
# SAP_OAUTH_CLIENT_ID=your-client-id
# SAP_OAUTH_CLIENT_SECRET=your-client-secret
# SAP_OAUTH_TOKEN_URL=https://your-tenant.authentication.hana.ondemand.com/oauth/token

SAP_SSL_VERIFY=true
SAP_MAX_RECORDS=5000

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini           # gemini | openai | azure_openai

# Gemini (default)
GEMINI_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# Azure OpenAI (alternative)
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21

# ─── Security ─────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Exports ──────────────────────────────────────────────────────────────────
EXPORT_DIR=/tmp/sap_chatbot_exports
MAX_EXPORT_ROWS=50000
