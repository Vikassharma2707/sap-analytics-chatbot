# ─────────────────────────────────────────────────────────────────────────────
# Copy these into Vercel Dashboard → Project → Settings → Environment Variables
# Set scope to: Production + Preview + Development (unless noted otherwise)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=SAP Analytics Chatbot
DEBUG=false
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_urlsafe(32))">

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → "Transaction pooler" string (port 6543)
# IMPORTANT: use the Transaction Pooler URL for Vercel (serverless NullPool mode)
# Replace the scheme: "postgresql://" → "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── Redis (Upstash — free serverless Redis) ─────────────────────────────────
# Create database at https://upstash.com → copy rediss:// URL
REDIS_URL=rediss://:<password>@<host>.upstash.io:6380

# ─── SAP S/4HANA Connection ───────────────────────────────────────────────────
SAP_BASE_URL=https://your-s4-system.yourcompany.com
SAP_CLIENT=100
SAP_AUTH_TYPE=basic
SAP_USERNAME=CHATBOT_USER
SAP_PASSWORD=<your-sap-password>
SAP_SSL_VERIFY=true
SAP_MAX_RECORDS=5000

# For OAuth 2.0 (BTP / SAP IAS):
# SAP_AUTH_TYPE=oauth2
# SAP_OAUTH_CLIENT_ID=<client-id>
# SAP_OAUTH_CLIENT_SECRET=<client-secret>
# SAP_OAUTH_TOKEN_URL=https://<tenant>.authentication.hana.ondemand.com/oauth/token

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza-<your-key>
GEMINI_MODEL=gemini-2.0-flash

# OR use OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-<your-key>
# OPENAI_MODEL=gpt-4o

# ─── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# ─── Exports (use /tmp on Vercel — ephemeral, fits within function lifetime) ──
EXPORT_DIR=/tmp/sap_chatbot_exports

# ─── Frontend (set as NEXT_PUBLIC_ so it is bundled into the browser build) ───
# On Vercel this is NOT needed — the frontend and backend share the same origin.
# Only set this if you deploy the frontend and backend as separate Vercel projects.
# NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api/v1
